# Optional managed cache root for Asteria adapter artifacts.
ASTERIAMCP_CACHE_ROOT=

# Optional override for the MCP system prompt.
ASTERIAMCP_SYSTEM_PROMPT=

# Optional override for get_symbols_overview tool description.
ASTERIAMCP_GET_SYMBOLS_OVERVIEW_DESC=

# Optional override for find_symbol tool description.
ASTERIAMCP_FIND_SYMBOL_DESC=

# Optional override for find_referencing_symbols tool description.
ASTERIAMCP_FIND_REFERENCES_DESC=

# Optional global timeout for one MCP tool call. Example: 10s, 30s, 1m.
ASTERIAMCP_TOOL_TIMEOUT=

# Optional override for the maximum serialized JSON size of one tool response.
ASTERIAMCP_TOOL_OUTPUT_MAX_BYTES=

# Optional gopls build flags, separated by ';'. Example: -tags=featurex;-tags=integration
ASTERIAMCP_GOPLS_BUILD_FLAGS=

# Optional gopls build environment entries, separated by ';'. Example: GOFLAGS=-tags=featurex;GOOS=linux
ASTERIAMCP_GOPLS_ENV=

# Optional rust-analyzer workspace symbol search limit.
ASTERIAMCP_RUST_ANALYZER_WORKSPACE_SYMBOL_SEARCH_LIMIT=

# Optional rust-analyzer startup ready timeout. Example: 30s.
ASTERIAMCP_RUST_ANALYZER_STARTUP_READY_TIMEOUT=